+// regression -- cheap stand-in for the paper's iterative tile-wise fit.
+float4 PSAnaPack(VSOut i) : SV_Target
+{
+    float3 c = srcTex.SampleLevel(samp, i.uv, 0.0).rgb;
+    return float4(c.r, c.g, c.r * c.g, c.r * c.r);
