+    SAFE_RELEASE(m_psRemap);
+    SAFE_RELEASE(m_psPack);
     SAFE_RELEASE(m_psCompose);
     SAFE_RELEASE(m_psSplit);
     SAFE_RELEASE(m_psSmooth);
