+bool Converter::EnsureRemap(int width, int height)
+{
+    if (m_packTex && width == m_remapW && height == m_remapH)
+        return false;
+
+    ReleaseRemap();
+
+    // m_packTex: (R, G, R*G, R*R) at source size, FULL mip chain so that
+    // GenerateMips gives tile-averaged means at every level. RGBA16F: products
+    // are in [0,1] but we want headroom and consistent precision across levels.
+    m_packMips = 1;
+    for (int w = width, h = height; w > 1 || h > 1; ) { w = (w > 1) ? w / 2 : 1; h = (h > 1) ? h / 2 : 1; ++m_packMips; }
+    D3D11_TEXTURE2D_DESC pd{};
+    pd.Width = (UINT)width; pd.Height = (UINT)height; pd.MipLevels = (UINT)m_packMips; pd.ArraySize = 1;
+    pd.Format = DXGI_FORMAT_R16G16B16A16_FLOAT; pd.SampleDesc.Count = 1; pd.Usage = D3D11_USAGE_DEFAULT;
+    pd.BindFlags = D3D11_BIND_RENDER_TARGET | D3D11_BIND_SHADER_RESOURCE;
+    pd.MiscFlags = D3D11_RESOURCE_MISC_GENERATE_MIPS;
+    if (FAILED(m_device->CreateTexture2D(&pd, nullptr, &m_packTex))) { ReleaseRemap(); return false; }
+    // RTV must reference mip 0 explicitly (we only ever write the finest level).
+    D3D11_RENDER_TARGET_VIEW_DESC rtvDesc{};
+    rtvDesc.Format = pd.Format;
+    rtvDesc.ViewDimension = D3D11_RTV_DIMENSION_TEXTURE2D;
+    rtvDesc.Texture2D.MipSlice = 0;
+    if (FAILED(m_device->CreateRenderTargetView(m_packTex, &rtvDesc, &m_packRTV))) { ReleaseRemap(); return false; }
+    if (FAILED(m_device->CreateShaderResourceView(m_packTex, nullptr, &m_packSRV))) { ReleaseRemap(); return false; }
+
+    // m_matchTex: (remapped R, original G, original B, 1) at source size. sRGB so
+    // gradWindow / buildDesc read it in the same linear space they'd read srcTex.
+    D3D11_TEXTURE2D_DESC md{};
+    md.Width = (UINT)width; md.Height = (UINT)height; md.MipLevels = 1; md.ArraySize = 1;
+    md.Format = m_format;   // R8G8B8A8 sRGB; matches srcTex's space
+    md.SampleDesc.Count = 1; md.Usage = D3D11_USAGE_DEFAULT;
+    md.BindFlags = D3D11_BIND_RENDER_TARGET | D3D11_BIND_SHADER_RESOURCE;
+    if (FAILED(m_device->CreateTexture2D(&md, nullptr, &m_matchTex))) { ReleaseRemap(); return false; }
+    if (FAILED(m_device->CreateRenderTargetView(m_matchTex, nullptr, &m_matchRTV))) { ReleaseRemap(); return false; }
+    if (FAILED(m_device->CreateShaderResourceView(m_matchTex, nullptr, &m_matchSRV))) { ReleaseRemap(); return false; }
+
+    m_remapW = width; m_remapH = height;
+    return true;
+}
+
+void Converter::ReleaseRemap()
+{
+    SAFE_RELEASE(m_matchSRV); SAFE_RELEASE(m_matchRTV); SAFE_RELEASE(m_matchTex);
+    SAFE_RELEASE(m_packSRV);  SAFE_RELEASE(m_packRTV);  SAFE_RELEASE(m_packTex);
+    m_packMips = 0;
+    m_remapW = m_remapH = 0;
+}
+
