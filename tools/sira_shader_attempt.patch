+// Joint-bilateral guided fill (cheap stand-in for SIRA's superpixel colorization).
+// For every pixel, output a weighted mean of itself + neighbours within a small
+// window, with weights = spatial Gaussian * preserved-channel-similarity Gaussian
+// * confidence. The PRESERVED CHANNEL (red on left eye, green on right) is the
+// guide image: it's the eye's own anaglyph channel and is always reliable, so
+// donors with similar preserved value belong to the same scene region. The range
+// Gaussian (sharp: sigma_r ~ 0.05) makes weights collapse across object edges,
+// so this naturally edge-stops without an explicit segmentation -- the trait
+// the push-pull pyramid lacks (its Gaussian downsamples blur across edges,
+// producing the marbelling). High-conf pixels are self-dominated (weight=me.a
+// against far smaller neighbour weights), so they pass through essentially
+// unchanged; low-conf pixels are filled by their confident neighbours. The
+// pixel's own preserved channel is rewritten verbatim on output so per-eye
+// luminance survives.
+//
+// Cost: (2*R+1)^2 samples per pixel, no branching, fully [unroll]ed. R=4 = 81
+// samples (vs the 441 of the previous superpixel-proxy attempt) and the push-pull
+// safety net catches holes too big for the bilateral to reach.
+float4 PSAnaColor(VSOut i) : SV_Target
+{
+    float2 uv = i.uv;
+    float4 me = srcTex.SampleLevel(samp, uv, 0.0);   // (rgb, conf)
+
+    bool right = uv.x >= 0.5;
+    float panLo = right ? 0.5 : 0.0;
+    float panHi = right ? 1.0 : 0.5;
+    // SBS is two source-width panes side-by-side, so one source pixel = 0.5/srcW
+    // in SBS UV space; vertically it's 1.0/srcH.
+    float px = 0.5 / max(g_srcW, 1.0);
+    float py = 1.0 / max(g_srcH, 1.0);
+
+    // Preserved channel = bilateral guide (red on left pane, green on right pane;
+    // mode 4 only runs for combo 0 so this mapping is unconditional here).
+    float gMe = right ? me.g : me.r;
+
+    // Self-weighted by own confidence; high-conf pixels dominate their own output,
+    // low-conf pixels effectively get replaced by their confident neighbours.
+    float3 acc = me.rgb * max(me.a, 1e-4);
+    float  wsum = max(me.a, 1e-4);
+
+    const int R = 4;
+    [unroll] for (int dy = -R; dy <= R; ++dy)
+    [unroll] for (int dx = -R; dx <= R; ++dx)
+    {
+        if (dx == 0 && dy == 0) continue;
+        float2 nuv = uv + float2((float)dx * px, (float)dy * py);
+        // Stay in this eye's pane (don't cross the SBS centerline) and in-frame.
+        if (nuv.x < panLo + 0.5 * px || nuv.x > panHi - 0.5 * px) continue;
+        if (nuv.y < 0.5 * py || nuv.y > 1.0 - 0.5 * py) continue;
+        float4 n = srcTex.SampleLevel(samp, nuv, 0.0);
+        float gN = right ? n.g : n.r;
+        float dg = gN - gMe;
+        // Spatial Gaussian (sigma_s ~ 2 px).
+        float ws = exp(-(float)(dx * dx + dy * dy) * 0.125);
+        // Preserved-channel range Gaussian (sigma_r ~ 0.05 -- sharp; ~3-stop drop
+        // for ~0.1 difference, so cross-region donors contribute almost nothing).
+        float wr = exp(-dg * dg * 200.0);
+        float w = n.a * ws * wr;
+        acc  += n.rgb * w;
+        wsum += w;
+    }
+
+    // Preserve the pixel's own anaglyph channel verbatim so per-eye luminance
+    // survives the colorization; only the missing channels come from the borrowed
+    // bilateral mean. Output alpha=1 -> push-pull treats this as already filled.
+    float3 filled = acc / wsum;
+    if (right) filled.g = me.g;
+    else       filled.r = me.r;
+    return float4(saturate(filled), 1.0);
+}
