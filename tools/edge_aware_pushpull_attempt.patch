+// level's dimensions (NOT the source frame's), used for the half-input-texel offsets.
+float4 PSAnaPyramidDown(VSOut i) : SV_Target
+{
+    float ix = 1.0 / max(g_srcW, 1.0);
+    float iy = 1.0 / max(g_srcH, 1.0);
+    float2 b = i.uv;
+    float4 s00 = srcTex.SampleLevel(samp, b + float2(-0.5 * ix, -0.5 * iy), 0.0);
+    float4 s10 = srcTex.SampleLevel(samp, b + float2(+0.5 * ix, -0.5 * iy), 0.0);
+    float4 s01 = srcTex.SampleLevel(samp, b + float2(-0.5 * ix, +0.5 * iy), 0.0);
+    float4 s11 = srcTex.SampleLevel(samp, b + float2(+0.5 * ix, +0.5 * iy), 0.0);
+
+    float3 c00 = s00.rgb / max(s00.a, 1e-4);
+    float3 c10 = s10.rgb / max(s10.a, 1e-4);
+    float3 c01 = s01.rgb / max(s01.a, 1e-4);
+    float3 c11 = s11.rgb / max(s11.a, 1e-4);
+    float3 Y3 = float3(0.299, 0.587, 0.114);
+    float y00 = dot(c00, Y3), y10 = dot(c10, Y3);
+    float y01 = dot(c01, Y3), y11 = dot(c11, Y3);
+
+    // Reference luminance = the most-confident input's luma. Picking a single
+    // anchor (rather than the mean) means cross-edge inputs are judged against
+    // the dominant-region's brightness, not against a halfway-blended value.
+    float refY = y00; float maxA = s00.a;
+    if (s10.a > maxA) { refY = y10; maxA = s10.a; }
+    if (s01.a > maxA) { refY = y01; maxA = s01.a; }
+    if (s11.a > maxA) { refY = y11; maxA = s11.a; }
