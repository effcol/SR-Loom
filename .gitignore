# Vendored SDKs / helper repos — large and partly proprietary (SR SDK) or
# differently licensed (ShaderGlass GPL, etc.). Not redistributed here; the
# SR SDK must be installed locally. See README.
/lib/

# Build output
/build/
/out/
*.exe
*.pdb
*.ilk
*.obj

# Visual Studio
.vs/
*.user
slnx.sqlite

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# tools/ holds the offline SIRA research script + saved-attempt patches, but
# test anaglyph images (often third-party) and the generated comparison
# outputs / parameter-sweep directories shouldn't be redistributed.
tools/*.jpg
tools/*.jpeg
tools/*.png
tools/sweep_*/

# Loose stereo / quilt test images + videos at the repo root. They live in
# lib/Test Images/ (already ignored via /lib/) -- this stops stray copies at
# the top level from getting committed by accident. README/docs images live
# under assets/, which is unaffected.
/*.png
/*.jpg
/*.jpeg
/*.bmp
/*.tga
/*.mp4
/*.mov
/*.mkv
/*.webm
/*.avi
/*.m4v
/*.wmv

# Local-only release-notes draft; not shipped in repo.
/CHANGELOG.md
