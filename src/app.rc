#include "resource.h"

// Tray / application icon: the white Dimenco logo mark on transparency.
IDI_TRAY ICON "../assets/sr_weaver.ico"

// UI fonts embedded into the exe (Inter, SIL Open Font License) — loaded from these
// resources at runtime so no font files need to ship beside the executable.
IDR_FONT_REGULAR  RCDATA "../assets/fonts/Inter-Regular.ttf"
IDR_FONT_SEMIBOLD RCDATA "../assets/fonts/Inter-SemiBold.ttf"

// NPClient.dll (x64) — TrackIR consumer DLL games load to receive head pose.
// Built by CMake from third_party/npclient/npclient.c (MIT, OpenTrack contrib)
// and copied here by the NPClient64 POST_BUILD step. Extracted on first launch
// to %LOCALAPPDATA%\SRLoom\NPClient\NPClient64.dll.
IDR_NPCLIENT64    RCDATA "../assets/npclient/NPClient64.dll"
